---
import { getCollection } from "astro:content";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { keywordLandingPages, keywordPagePath } from "../../seo-pages";

const posts = (await getCollection("blog")).sort(
  (left, right) => right.data.publishedAt.getTime() - left.data.publishedAt.getTime()
);

const workflowPaths = [
  {
    title: "Growing agent-built projects",
    description:
      "Keep product intent, architecture choices, open questions, and setup paths visible as experiments become real repositories.",
    href: "/blog/watching-multiple-agent-built-projects-with-memory/",
    tags: ["Project state", "Viewer", "Multi-project"]
  },
  {
    title: "Professional agent-assisted development",
    description:
      "Give recurring coding sessions task-shaped context, reduce repeated briefing, and keep durable discoveries reviewable in Git.",
    href: "/persistent-memory-ai-coding-agents/",
    tags: ["Persistent memory", "Review", "Context"]
  },
  {
    title: "Small agent instruction files",
    description:
      "Use `AGENTS.md`, `CLAUDE.md`, and Cursor rules for behavior while Memory carries changing project knowledge.",
    href: "/blog/keeping-agents-md-and-claude-md-small/",
    tags: ["AGENTS.md", "CLAUDE.md", "Rules"]
  },
  {
    title: "Shared context across agent tools",
    description:
      "Let Codex, Claude Code, Cursor, Cline, OpenCode, and MCP-capable clients load the same local project memory.",
    href: "/codex-memory/",
    tags: ["Codex", "Claude Code", "Cursor"]
  }
];
---

<BaseLayout
  title="AI Coding Agent Memory Use Cases - Memory by Aictx"
  description="Use cases for persistent project memory, MCP memory, Codex memory, Claude Code memory, and Cursor memory with Memory by Aictx."
>
  <main>
    <section class="blog-hero use-cases-hero" aria-labelledby="use-cases-title">
      <div class="use-cases-hero-panel">
        <p class="section-kicker">Use cases</p>
        <h1 id="use-cases-title">Where durable context helps AI coding agents.</h1>
        <p>
          Practical paths for better agent work, fewer repeated briefings, and
          reviewable project memory as repos keep evolving.
        </p>
      </div>
    </section>

    <section class="blog-list-section" aria-label="Use case articles">
      <div class="section-heading">
        <h2>Start with the pain you recognize.</h2>
        <p>
          Memory is useful when context starts repeating, drifting, or hiding in
          chat history instead of becoming project state.
        </p>
      </div>

      <div class="blog-list workflow-list">
        {
          workflowPaths.map((path) => (
            <article class="post-card workflow-card">
              <a href={path.href}>
                <h2>{path.title}</h2>
                <p>{path.description}</p>
                <div class="post-tags" aria-label={`${path.title} topics`}>
                  {path.tags.map((tag) => (
                    <span>{tag}</span>
                  ))}
                </div>
              </a>
            </article>
          ))
        }
      </div>

      <div class="section-heading use-cases-post-heading">
        <h2>Guides by workflow.</h2>
        <p>
          Search-focused guides for persistent memory, MCP memory, and
          project-memory workflows in Codex, Claude Code, and Cursor.
        </p>
      </div>

      <div class="blog-list">
        {
          keywordLandingPages.map((page) => (
            <article class="post-card">
              <a href={keywordPagePath(page)}>
                <h2>{page.kicker}</h2>
                <p>{page.description}</p>
                <div class="post-tags" aria-label={`${page.kicker} keywords`}>
                  {page.keywords.slice(0, 4).map((keyword) => (
                    <span>{keyword}</span>
                  ))}
                </div>
              </a>
            </article>
          ))
        }
      </div>

      <div class="section-heading use-cases-post-heading">
        <h2>Field notes.</h2>
        <p>Practical examples from using Memory with real agent workflows.</p>
      </div>

      {
        posts.length > 0 ? (
          <div class="blog-list">
            {posts.map((post) => (
              <PostCard
                title={post.data.title}
                description={post.data.description}
                href={`/blog/${post.id}/`}
                publishedAt={post.data.publishedAt}
                tags={post.data.tags}
              />
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <h2>No use cases published yet.</h2>
            <p>Markdown posts added under <code>site/src/content/blog</code> will appear here newest first.</p>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>
