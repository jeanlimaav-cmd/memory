---
import GitHubIcon from "../components/GitHubIcon.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const viewerUrl = "https://demo.aictx.dev/?token=demo";
---

<BaseLayout>
  <main id="top">
    <section class="hero">
      <div class="hero-panel">
        <a
          class="eyebrow-link"
          href="https://github.com/aictx/memory"
          aria-label="Open the aictx/memory GitHub repository"
          rel="noreferrer"
        >
          <GitHubIcon />
          aictx/memory
        </a>
        <h1 class="hero-title">
          <span class="hero-title-desktop">Stop re&#8209;explaining your</span>
          <span class="hero-title-desktop">repo to AI agents.</span>
          <span class="hero-title-mobile">Stop re&#8209;explaining</span>
          <span class="hero-title-mobile">your repo to AI agents.</span>
        </h1>

        <p class="hero-identity">
          <span class="hero-identity-line">Memory is a local wiki for AI agents.</span>
          <span class="hero-identity-line">They load repo context, keep it current, and you review the changes.</span>
        </p>

        <div class="hero-install" aria-label="Install Memory">
          <div class="hero-commands" aria-label="Install commands">
            <div class="hero-command">
              <span>Homebrew</span>
              <code>brew install aictx/tap/memory</code>
            </div>
            <div class="hero-command">
              <span>npm</span>
              <code>npm install -g @aictx/memory</code>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section
      class="value-section context-section"
      id="context"
      aria-labelledby="context-title"
    >
      <div class="value-section-inner">
        <div class="section-heading">
          <h2 id="context-title">Why Memory?</h2>
          <p>
            Give agents durable project context they can load, keep current, and
            leave reviewable without turning every prompt or instruction file
            into a wiki.
          </p>
        </div>

        <div class="comparison comparison-why" aria-label="Why use Memory">
          <div>
            <span>01</span>
            <strong>Preserve decisions that should survive.</strong>
            <p>
              Keep product intent, architecture choices, workflows, conventions,
              and gotchas available after the chat that discovered them is gone.
            </p>
          </div>
          <div>
            <span>02</span>
            <strong>Load only what the task needs.</strong>
            <p>
              Agents pull focused context before work, so repeated briefings and
              stale all-purpose prompts do not consume the attention budget.
            </p>
          </div>
          <div>
            <span>03</span>
            <strong>Make memory observable.</strong>
            <p>
              Inspect the same local entries agents use, review the diff, and
              repair stale facts before they steer the next session.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section
      class="payoff-section"
      id="payoff"
      aria-labelledby="payoff-title"
    >
      <div class="payoff-inner">
        <div class="payoff-heading">
          <p class="section-kicker">When it pays off</p>
          <h2 id="payoff-title">When context starts repeating, Memory becomes leverage.</h2>
          <p>
            It is useful long before a repo is huge: whenever decisions,
            corrections, and workflows should outlive one agent session.
          </p>
        </div>

        <div class="payoff-grid" aria-label="When Memory is useful">
          <article>
            <span>Same repo, new session</span>
            <strong>Agents stop starting from a blank chat.</strong>
            <p>
              The next session can load the project shape, active constraints,
              setup path, and sharp edges before touching code.
            </p>
          </article>
          <article>
            <span>Scattered decisions</span>
            <strong>Project knowledge gets one reviewable home.</strong>
            <p>
              Product notes, architecture choices, and user corrections do not
              have to live across prompts, docs, and old transcripts.
            </p>
          </article>
          <article>
            <span>Several agent tools</span>
            <strong>Different clients can share the same context.</strong>
            <p>
              Codex, Claude Code, Cursor, Cline, OpenCode, and MCP-capable tools
              can all work from the same local project memory.
            </p>
          </article>
          <article>
            <span>Useful discoveries</span>
            <strong>The next agent inherits the durable parts.</strong>
            <p>
              Save the reusable fact, workflow, gotcha, or synthesis instead of
              asking future agents to mine the whole chat.
            </p>
          </article>
        </div>

        <div class="payoff-strip" aria-label="Memory value stack">
          <span>Better starting context</span>
          <span>Less repeated briefing</span>
          <span>Reviewable memory trail</span>
        </div>
      </div>
    </section>

    <section
      class="impact-section"
      id="before-after"
      aria-labelledby="before-after-title"
    >
      <div class="section-heading">
        <h2 id="before-after-title">Proof in the first five minutes.</h2>
        <p>
          The agent starts with the right durable context, spends less time
          rediscovering old decisions, and leaves a memory trail you can review
          before the next session depends on it.
        </p>
      </div>

      <div class="impact-module impact-module-single" style="--reveal: 50%">
        <div class="impact-visual">
          <div
            class="impact-visual-panel is-active"
            id="impact-context"
            data-impact-panel="impact-context"
          >
            <div class="comparison-labels" aria-hidden="true">
              <span>Before</span>
              <span>After</span>
            </div>
            <div class="comparison-state" aria-hidden="true">Compare</div>
            <div class="scene-layer before">
              <div
                class="codex-chat codex-chat-before"
                aria-label="Codex chat without Memory"
              >
                <div class="codex-chat-topbar">
                  <span>Update viewer search behavior</span>
                  <strong>•••</strong>
                </div>
                <div class="codex-user-bubble">
                  <p>Can you polish viewer search?</p>
                </div>
                <div class="codex-work-pill">Worked for 7m 18s⌄</div>
                <div class="codex-divider"></div>
                <div class="codex-response">
                  <p>
                    I need to inspect the docs and viewer code to recover the
                    product direction.
                  </p>
                </div>
                <div class="codex-command-row">
                  <span aria-hidden="true">›</span>
                  Ran <code>rg "viewer|search|schema|facets"</code>
                </div>
                <div class="codex-command-row">
                  <span aria-hidden="true">›</span>
                  Read <code>docs/viewer.md</code>, <code
                    >viewer/src/App.svelte</code
                  >
                </div>
                <div class="codex-command-row muted-row">
                  <span aria-hidden="true">›</span>
                  Explored 11 files, 4 searches
                </div>
                <div class="codex-response warning-message">
                  <p>
                    Remind me: are we still avoiding dashboard-style UI here?
                  </p>
                </div>
              </div>
            </div>
            <div class="scene-layer after">
              <div
                class="codex-chat codex-chat-after"
                aria-label="Codex chat with Memory"
              >
                <div class="codex-chat-topbar">
                  <span>Update viewer search behavior</span>
                  <strong>•••</strong>
                </div>
                <div class="codex-user-bubble">
                  <p>Can you polish viewer search?</p>
                </div>
                <div class="codex-command-row memory-command-row">
                  <span aria-hidden="true">›</span>
                  Ran <code>memory load "improve viewer search UI"</code>
                </div>
                <div class="memory-context-pack">
                  <span>AI Context Pack</span>
                  <strong
                    >Viewer memory page shows canonical types, facets, scopes,
                    and relations first.</strong
                  >
                  <p>
                    Keep guided lenses secondary. Verify schema filters and
                    relation boundaries.
                  </p>
                </div>
                <div class="codex-command-row muted-row">
                  <span aria-hidden="true">›</span>
                  Loaded 6 relevant memories before editing
                </div>
                <div class="codex-response ready-message">
                  <p>
                    I have the UI constraint and verification path. I’ll update
                    search without reopening old decisions.
                  </p>
                </div>
              </div>
            </div>
            <span class="reveal-divider" aria-hidden="true"></span>
            <input
              class="reveal-scrubber"
              type="range"
              min="0"
              max="100"
              value="50"
              aria-label="Slide between before and after for context loading"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="demo-section" id="demo" aria-labelledby="demo-title">
      <div class="section-heading">
        <h2 id="demo-title">Inspect the memory schema and graph.</h2>
      </div>

      <div class="demo-art">
        <a class="viewer-frame" href={viewerUrl} rel="noreferrer">
          <span class="browser-bar">
            <i></i>
            <i></i>
            <i></i>
            <code>demo.aictx.dev</code>
          </span>
          <img
            src="/assets/viewer-demo.png"
            alt="Memory viewer showing the memory schema graph with relation overview and canonical storage navigation."
          />
        </a>
      </div>

      <div class="demo-footer">
        <p>
          Browse a local memory database with canonical object types, facet
          categories, relation overviews, provenance links, and graph context.
        </p>
        <a class="text-link" href={viewerUrl} rel="noreferrer"> Open viewer </a>
      </div>
    </section>
  </main>

  <script>
    const revealControls = document.querySelectorAll(".reveal-scrubber");

    for (const control of revealControls) {
      const module = control.closest(".impact-module");
      const setReveal = () => {
        module?.style.setProperty("--reveal", `${control.value}%`);
        module?.style.setProperty(
          "--handle",
          `clamp(28px, ${control.value}%, calc(100% - 28px))`,
        );
        const state = control
          .closest("[data-impact-panel]")
          ?.querySelector(".comparison-state");
        if (state) {
          state.textContent =
            control.value === "0"
              ? "Showing after"
              : control.value === "100"
                ? "Showing before"
                : "Compare";
        }
      };

      control.addEventListener("input", setReveal);
      if (
        control.closest("[data-impact-panel]")?.classList.contains("is-active")
      ) {
        setReveal();
      }
    }
  </script>
</BaseLayout>
